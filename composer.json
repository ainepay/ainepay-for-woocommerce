{
	"name": "ainepay/ainepay-for-woocommerce",
	"description": "Accept non-custodial USDT/USDC stablecoin payments through AinePay in WooCommerce.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"woocommerce",
		"payment-gateway",
		"stablecoin",
		"usdt",
		"usdc",
		"ainepay"
	],
	"authors": [
		{
			"name": "AinePay",
			"email": "support@ainepay.com",
			"homepage": "https://ainepay.com"
		}
	],
	"support": {
		"email": "support@ainepay.com",
		"issues": "https://github.com/ainepay/ainepay-for-woocommerce/issues"
	},
	"require": {
		"php": ">=8.1",
		"ext-hash": "*",
		"ext-json": "*",
		"kornrunner/keccak": "^1.1",
		"bacon/bacon-qr-code": "^3.1"
	},
	"require-dev": {
		"doctrine/instantiator": "^1.5",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"phpunit/phpunit": "^9.6",
		"wp-coding-standards/wpcs": "^3.3"
	},
	"autoload": {
		"classmap": [
			"includes/"
		]
	},
	"scripts": {
		"lint": "find . -type f -name '*.php' -not -path './vendor/*' -not -path './dist/*' -print0 | xargs -0 -n1 php -l",
		"phpcs": "phpcs -q",
		"test": "phpunit -c phpunit.xml.dist",
		"test:wc-integration": "bash bin/test-wc-integration.sh",
		"verify-release": "bash bin/verify-release.sh"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"optimize-autoloader": true,
		"platform": {
			"php": "8.1.0"
		},
		"sort-packages": true
	}
}
